# 江浙沪旅游行程规划系统 - 环境配置模板

# ========================================
# 前端配置
# ========================================

# 禁用主机检查，添加 HOST 配置
DANGEROUSLY_DISABLE_HOST_CHECK=true
HOST=localhost

# 高德地图 API Key 配置
# 请访问 https://console.amap.com/ 获取您的API密钥
REACT_APP_AMAP_KEY=b92f93fc83cd2fae8e394acb5b2dc5d9

# ========================================
# 后端配置
# ========================================

# GLM API Key (用于AI行程生成)
# 请访问 https://open.bigmodel.cn/ 获取您的API密钥
GLM_API_KEY=your-glm-api-key-here

# JWT密钥 (用于用户认证)
# 请修改为一个随机字符串
SECRET_KEY=your-secret-key-change-in-production

# 数据库配置
# SQLite数据库文件路径
DATABASE_URL=sqlite:///./travel_planner.db

# 前端URL (用于CORS配置)
FRONTEND_URL=http://localhost:3000

# ========================================
# 端口配置
# ========================================

# 后端服务端口
BACKEND_PORT=8000

# 前端服务端口
FRONTEND_PORT=3000

# ========================================
# 其他配置
# ========================================

# 调试模式 (生产环境设置为false)
DEBUG=true

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ========================================
# 注意事项
# ========================================
# 1. 将此文件复制为 .env 文件
# 2. 填入您的API密钥
# 3. 根据需要修改端口配置
# 4. 生产环境请修改SECRET_KEY
