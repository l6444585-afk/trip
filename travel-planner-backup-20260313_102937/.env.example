# ===========================================
# 江浙沪旅游行程规划系统 - 环境变量配置
# ===========================================
# 请复制此文件为 .env 并填写实际值
# cp .env.example .env

# ===========================================
# 环境配置 (必填)
# ===========================================
# 可选值: development, staging, production
ENVIRONMENT=development

# 调试模式 (生产环境必须为 false)
DEBUG=false

# ===========================================
# 安全配置 (生产环境必填)
# ===========================================
# JWT 密钥 - 生产环境必须设置安全的随机密钥
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# Token 过期时间 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# AI 服务配置 (至少配置一个)
# ===========================================
# 智谱 AI API 密钥
# 获取地址: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here

# SiliconFlow API 密钥 (备选)
# 获取地址: https://siliconflow.cn/
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ===========================================
# 地图服务配置
# ===========================================
# 高德地图 API 密钥
# 获取地址: https://lbs.amap.com/
AMAP_API_KEY=your_amap_api_key_here

# ===========================================
# CORS 配置 (生产环境必填)
# ===========================================
# 允许的前端域名，多个用逗号分隔
# 开发环境: http://localhost:3000,http://127.0.0.1:3000
# 生产环境: https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===========================================
# 数据库配置
# ===========================================
# 开发环境使用 SQLite
DATABASE_URL=sqlite:///./travel_planner.db
ENHANCED_DATABASE_URL=sqlite:///./travel_planner_enhanced.db

# 生产环境建议使用 PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/travel_planner

# ===========================================
# 演示用户配置
# ===========================================
# 是否启用演示用户 (生产环境建议关闭)
DEMO_USER_ENABLED=true
DEMO_USER_USERNAME=admin
DEMO_USER_PASSWORD=admin123

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO
LOG_DIR=logs

# ===========================================
# 缓存配置
# ===========================================
CACHE_TTL=3600
SESSION_MAX_AGE=86400
MAX_SESSIONS=1000

# ===========================================
# 前端配置 (前端项目使用)
# ===========================================
REACT_APP_AMAP_KEY=your_amap_api_key_here
